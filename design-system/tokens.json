{
  "$meta": {
    "name": "TELOS Design Tokens",
    "version": "1.0",
    "description": "The single source of truth for TELOS design tokens. Edit THIS file, then run `npm run sync:design` (from Code/web) to regenerate every consumer. Never hand-edit the generated files.",
    "feeling": "A visual language between earth and precision — warm, earthen, quiet. Soil and growth, never tech and chrome. Basil is the soul, used like punctuation."
  },
  "color": {
    "foundation": {
      "void": "#0c0c0a",
      "soil": "#181815",
      "earth": "#232320",
      "bark": "#333330",
      "stone": "#606058",
      "ash": "#9a9a92",
      "fog": "#c6c5be",
      "parchment": "#eeede8"
    },
    "accent": {
      "basil": "#89a83e",
      "moss": "#3e5230",
      "terra": "#a8593a",
      "mineral": "#3a4d4a"
    },
    "semantic": {
      "primary": "accent.basil",
      "success": "accent.basil",
      "warning": "accent.terra",
      "data": "accent.mineral",
      "surface": "foundation.soil",
      "surface2": "foundation.earth",
      "bg": "foundation.void",
      "text": "foundation.parchment",
      "textMuted": "foundation.ash",
      "textDim": "foundation.stone"
    },
    "cssSemanticAliases": ["success", "warning", "data"]
  },
  "font": {
    "display_en": "'Cormorant Garamond', Georgia, serif",
    "body_en": "'Plus Jakarta Sans', system-ui, sans-serif",
    "display_he": "'Noto Serif Hebrew', 'Cormorant Garamond', serif",
    "body_he": "'Rubik', 'Plus Jakarta Sans', system-ui, sans-serif",
    "numbers": "'Cormorant Garamond', Georgia, serif"
  },
  "fontSize": {
    "xs": "0.58rem",
    "sm": "0.75rem",
    "base": "0.95rem",
    "md": "1.25rem",
    "lg": "1.8rem",
    "xl": "2.5rem",
    "2xl": "4rem"
  },
  "tracking": {
    "tight": "0.02em",
    "normal": "0.05em",
    "wide": "0.15em",
    "label": "0.28em",
    "logo": "0.18em"
  },
  "space": { "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32, "10": 40, "12": 48, "16": 64 },
  "radius": { "none": "0px", "sm": "4px", "md": "8px", "lg": "14px", "pill": "999px" },
  "border": {
    "subtle": "1px solid rgba(238,237,232,0.07)",
    "dim": "1px solid rgba(238,237,232,0.12)",
    "basil": "1px solid rgba(137,168,62,0.25)"
  },
  "motion": {
    "easing": {
      "out": "cubic-bezier(0.22, 1, 0.36, 1)",
      "in": "cubic-bezier(0.64, 0, 0.78, 0)"
    },
    "duration": { "fast": 150, "base": 280, "slow": 600, "scene": 1400 }
  },
  "taglines": {
    "primary": "Every plant, its fullest self.",
    "secondary": "Not optimized. Fulfilled."
  }
}
