# === GrowK Configuration ===
# Copy this file to .env and fill in your values. NEVER commit .env.

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-...
# Sonnet 4.6 is the default. Override to claude-opus-4-7 for max reasoning,
# or claude-haiku-4-5 for cost optimization.
CLAUDE_MODEL=claude-sonnet-4-6

# --- Tuya Cloud API (sensor) ---
# Create at https://platform.tuya.com → Cloud Project → Smart Home, Central Europe
TUYA_ACCESS_ID=your_access_id
TUYA_ACCESS_SECRET=your_access_secret
TUYA_API_ENDPOINT=https://openapi.tuyaeu.com
# Device ID of the PH-W218 (Devices tab on platform.tuya.com after linking app)
TUYA_SENSOR_DEVICE_ID=your_device_id

# --- Jebao Doser (Gizwits cloud) ---
JEBAO_USERNAME=your_jebao_app_email
JEBAO_PASSWORD=your_jebao_app_password
# Region: eu | us | cn. Israel accounts are typically on us.
JEBAO_REGION=us

# --- System cadence ---
# Sensor polling stays fast for monitoring; decisions are hourly-scale.
SENSOR_POLL_INTERVAL=30          # seconds
AI_CYCLE_INTERVAL=3600           # seconds (1 hour). The AI may shorten via next_check_minutes.
LOG_LEVEL=INFO

# --- HTTP API for the dashboard ---
# Bearer token for /api/* — leave empty for dev (no auth)
GROWK_API_TOKEN=
GROWK_API_HOST=127.0.0.1
GROWK_API_PORT=8765
# Comma-separated origins, or "*" for dev
GROWK_CORS_ORIGINS=*

# --- Grow Profile ---
SYSTEM_TYPE=nft_wall_mounted
RESERVOIR_LITERS=60
CROP_TYPE=lettuce
# Optional cultivar id from growk/cultivars/ (e.g. basilico-genovese-dop).
# When set, the Brain reasons at cultivar level: provenance, stage-tuned bands,
# stress signatures, harvest markers. Empty = resolve CROP_TYPE against the registry.
CULTIVAR_ID=
